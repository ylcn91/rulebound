{
  "name": "rulebound",
  "version": "0.1.0",
  "private": true,
  "description": "Open source AI coding agent rule enforcement platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build --filter './packages/**' --filter './apps/**'",
    "build:all": "turbo build && pnpm run build:sdks",
    "build:sdks": "bash ./scripts/build-sdks.sh",
    "lint": "turbo lint",
    "test": "turbo run test --filter './packages/**' --filter './apps/**'",
    "test:all": "turbo test && pnpm run test:sdks",
    "test:sdks": "bash ./scripts/test-sdks.sh",
    "smoke:cli": "bash ./scripts/smoke-test-cli.sh",
    "release:gate": "bash ./scripts/release-gate.sh",
    "check:rulebound": "turbo run build --filter=@rulebound/cli && node packages/cli/dist/index.js check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "claude": "bash ./scripts/claude-rb.sh"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.28.2"
}
