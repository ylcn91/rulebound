{
  "name": "@rulebound/lsp",
  "version": "0.1.0",
  "description": "LSP server for Rulebound — inline diagnostics for rule violations in IDEs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rulebound-lsp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rulebound/engine": "workspace:*",
    "@rulebound/shared": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
