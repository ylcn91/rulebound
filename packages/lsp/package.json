{
  "name": "@rulebound/lsp",
  "version": "0.1.0",
  "description": "experimental: LSP server for Rulebound — inline diagnostics for rule violations in IDEs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rulebound/rulebound.git",
    "directory": "packages/lsp"
  },
  "homepage": "https://github.com/rulebound/rulebound#readme",
  "bugs": {
    "url": "https://github.com/rulebound/rulebound/issues"
  },
  "keywords": ["rulebound", "lsp", "language-server", "ide"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "bin": {
    "rulebound-lsp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rulebound/engine": "workspace:*",
    "@rulebound/shared": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
