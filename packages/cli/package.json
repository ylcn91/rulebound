{
  "name": "@rulebound/cli",
  "version": "0.1.0",
  "description": "Rulebound CLI — deterministic guardrails for AI coding agents (init, check, doctor, heal, validate, diff, ci)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rulebound/rulebound.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/rulebound/rulebound#readme",
  "bugs": {
    "url": "https://github.com/rulebound/rulebound/issues"
  },
  "keywords": [
    "rulebound",
    "ai",
    "agent",
    "cli",
    "rules",
    "guardrails",
    "deterministic",
    "policy-as-code"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "rulebound": "./dist/index.js"
  },
  "files": [
    "dist",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-examples.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node scripts/copy-examples.mjs"
  },
  "dependencies": {
    "@rulebound/engine": "workspace:*",
    "@rulebound/shared": "workspace:*",
    "chalk": "^5",
    "commander": "^14",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@ai-sdk/anthropic": "^3.0.48",
    "@ai-sdk/openai": "^3.0.36",
    "ai": "^6.0.103"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^4.1.6"
  }
}
