{
  "name": "@rulebound/engine",
  "version": "0.1.0",
  "description": "Core validation engine for Rulebound — rule loading, matching, and enforcement",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rulebound/shared": "workspace:*",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.24.7"
  },
  "optionalDependencies": {
    "@ai-sdk/anthropic": "^3.0.48",
    "@ai-sdk/openai": "^3.0.36",
    "ai": "^6.0.103",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
