{
  "name": "@rulebound/engine",
  "version": "0.1.0",
  "description": "Core validation engine for Rulebound — rule loading, matching, and enforcement",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rulebound/rulebound.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/rulebound/rulebound#readme",
  "bugs": {
    "url": "https://github.com/rulebound/rulebound/issues"
  },
  "keywords": ["rulebound", "engine", "rules", "deterministic", "validation"],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rulebound/shared": "workspace:*",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.24.7"
  },
  "optionalDependencies": {
    "@ai-sdk/anthropic": "^3.0.48",
    "@ai-sdk/openai": "^3.0.36",
    "ai": "^6.0.103",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
