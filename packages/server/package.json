{
  "name": "@rulebound/server",
  "version": "0.1.0",
  "description": "preview: self-hosted HTTP API server for Rulebound — centralized rule management, validation, webhooks, audit. Not a hosted SaaS; not part of the stable core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rulebound/rulebound.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/rulebound/rulebound#readme",
  "bugs": {
    "url": "https://github.com/rulebound/rulebound/issues"
  },
  "keywords": [
    "rulebound",
    "server",
    "api",
    "drizzle",
    "postgres"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "rulebound-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --experimental-strip-types --no-warnings ./src/db/migrate.ts",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@rulebound/engine": "workspace:*",
    "@rulebound/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.14.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22",
    "drizzle-kit": "^0.31.9",
    "hono": "^4.12.18",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^4.1.6"
  }
}
