{
  "name": "@rulebound/server",
  "version": "0.1.0",
  "description": "Enterprise API server for Rulebound — centralized rule management, validation, webhooks, audit",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rulebound-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rulebound/engine": "workspace:*",
    "@rulebound/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.14.0",
    "@types/node": "^22",
    "drizzle-kit": "^0.31.9",
    "hono": "^4.7.0",
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  }
}
